# .gitignore — что НЕ коммитить в git

# ═══ Виртуальное окружение ═══
.venv/
__pycache__/
*.pyc
*.pyo

# ═══ IDE ═══
.vscode/
.idea/
*.swp
*.swo

# ═══ Сборка ═══
dist/
build/
*.egg-info/

# ═══ ДАННЫЕ (не в git сервера!) ═══
workspace/
# _SESSION_LOG.md — рантайм-лог фактов (пишется state_manager в корень репо), НЕ исходник
_SESSION_LOG.md

# ═══ Тесты (I1): КОД версионируется; артефакты прогона — нет ═══
.pytest_cache/
tests/**/__pycache__/

# ═══ Внешний coding-агент (MiMo) — рабочая директория, не часть проекта ═══
.mimocode/

# ═══ Секреты ═══
.env
.env.local
*.key

# ═══ Техническая документация ═══
docs/dev/

# ═══ Туннель (cloudflared) — D11, D31 ═══
# ВНИМАНИЕ: в .gitignore инлайн-комментарии НЕ работают — '#' в середине строки
# становится частью паттерна. Комментарии только на ОТДЕЛЬНОЙ строке.
# локальный бинарь туннеля
bin/cloudflared
# credentials именованного туннеля
*.cloudflared.json
# креды/конфиг cloudflared
.cloudflared/
# D31: может содержать tunnel_token — НЕ коммитить
config/tunnel.yaml
